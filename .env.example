# AuthBridge MCP Server — Environment Variables
# Copy this file to .env and fill in your values

# ── Required ──────────────────────────────────────────────────────────────────


# ── Optional ──────────────────────────────────────────────────────────────────

# FHIR server base URL
# Default: HAPI FHIR public sandbox (synthetic data)
# FHIR_BASE_URL=https://hapi.fhir.org/baseR4

# Server transport (sse for HTTP deployment, stdio for local CLI)
# MCP_TRANSPORT=sse

# Server host and port (Render sets PORT automatically)
# HOST=0.0.0.0
# PORT=8000
