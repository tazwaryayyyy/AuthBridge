# AuthBridge MCP Server — Environment Variables
# Copy this file to .env and fill in your values

# ── Required ──────────────────────────────────────────────────────────────────

# GitHub Personal Access Token (free — get at github.com/settings/tokens)
# Needs Models: Read-only permission
GITHUB_TOKEN=your_token_here

# ── Optional ──────────────────────────────────────────────────────────────────

# FHIR server base URL (default: HAPI FHIR public sandbox)
# FHIR_BASE_URL=https://hapi.fhir.org/baseR4

# MCP_TRANSPORT=sse
# HOST=0.0.0.0
# PORT=8000
